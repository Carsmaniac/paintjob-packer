offset_right = 738.0
offset_bottom = 414.0
text = "I acknowledge the traditional owners of the land on which Paint Job Packer was developed, the first nations people past, present and emerging, the Knowledge Holders and caretakers of this land. I acknowledge that sovereignty was never ceded. This always has been and always will be Aboriginal land.

I acknowledge that land rights have not been restored, that Indigenous Australians are not treated fairly by our justice system, and that we have a long way to go towards true reconciliation. "
horizontal_alignment = 1
autowrap_mode = 3

